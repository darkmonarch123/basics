<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Dashboard | FeedbackFlow</title>
    <style>
    :root {
        --primary: #2563eb;
        --primary-hover: #1d4ed8;
        --bg: #f8fafc;
        --card-bg: #ffffff;
        --text-main: #0f172a;
        --text-muted: #64748b;
        --transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

    /* Entrance Animation */
    @keyframes fadeInUp {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }

    body { 
        font-family: 'Inter', system-ui, sans-serif; 
        margin: 0; background: var(--bg); color: var(--text-main);
        animation: fadeInUp 0.6s ease-out;
    }

    /* Layout */
    .container { display: flex; height: 100vh; }
    
    nav { 
        width: 260px; background: #0f172a; color: white; padding: 30px 20px;
        box-shadow: 4px 0 10px rgba(0,0,0,0.05);
    }

    main { flex-grow: 1; padding: 50px; overflow-y: auto; }

    /* Modern SaaS Cards */
    .stats-grid { 
        display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); 
        gap: 25px; margin-bottom: 40px; 
    }

    .card { 
        background: var(--card-bg); padding: 25px; border-radius: 16px;
        border: 1px solid #e2e8f0; transition: var(--transition);
        animation: fadeInUp 0.8s ease-out;
    }

    .card:hover { 
        transform: translateY(-5px); 
        box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.1);
        border-color: var(--primary);
    }

    /* Dashboard Logic: Typography */
    .card h4 { margin: 0 0 10px 0; color: var(--text-muted); font-size: 0.9rem; text-transform: uppercase; letter-spacing: 0.05em; }
    .card .value { font-size: 2.2rem; font-weight: 800; color: var(--text-main); }

    /* Button Styling */
    .cta-btn {
        background: var(--primary); color: white; padding: 12px 24px;
        border-radius: 8px; text-decoration: none; font-weight: 600;
        display: inline-block; transition: var(--transition);
        border: none; cursor: pointer;
    }

    .cta-btn:hover { background: var(--primary-hover); transform: scale(1.05); }

    /* Animated Table */
    table { width: 100%; border-collapse: separate; border-spacing: 0 10px; }
    tr { transition: var(--transition); }
    tr:hover td { background: #f1f5f9; }
    td { padding: 16px; background: white; }
    td:first-child { border-radius: 10px 0 0 10px; }
    td:last-child { border-radius: 0 10px 10px 0; }

    /* Code Block Styling */
    .code-block { 
        background: #1e293b; color: #38bdf8; padding: 20px; 
        border-radius: 12px; font-family: 'Fira Code', monospace; font-size: 0.85rem;
        position: relative; overflow: hidden;
    }
</style>
</head>
<body>

    <nav>
        <h2>FeedbackFlow</h2>
        <p>Logged in as: <br><strong><%= user.email %></strong></p>
        <p style="color: #fbbf24;">Plan: <%= user.plan %></p>
    </nav>

    <main>
        <h1>Your Customer Feedback</h1>
        
        <div style="background: white; padding: 20px; border-radius: 8px; margin-bottom: 30px;">
            <h3>Install your widget</h3>
            <p>Copy and paste this right before your closing <code>&lt;/body&gt;</code> tag:</p>
            <div class="code-block">
                &lt;script&gt;<br>
                &nbsp;&nbsp;window.FeedbackFlowConfig = { tenantId: '<%= user.id %>', color: '#10b981' };<br>
                &lt;/script&gt;<br>
                &lt;script src="http://localhost:3000/widget.js"&gt;&lt;/script&gt;
            </div>
        </div>

        <table>
            <tr>
                <th>Date</th>
                <th>User Email</th>
                <th>Feedback Message</th>
            </tr>
            <% if (feedbacks.length > 0) { %>
                <% feedbacks.forEach(function(fb) { %>
                    <tr>
                        <td><%= fb.date %></td>
                        <td><strong><%= fb.userEmail %></strong></td>
                        <td><%= fb.message %></td>
                    </tr>
                <% }); %>
            <% } else { %>
                <tr><td colspan="3">No feedback yet. Install the widget to get started!</td></tr>
            <% } %>
        </table>
    </main>

    <script>
        window.FeedbackFlowConfig = { tenantId: '<%= user.id %>', color: '#1e293b' };
    // CEO Logic: Calculating "Health Metrics"
    var totalViews = 1000; // Mock data for now
    // var totalSubmissions = <%= feedbacks.length %>;
    
    // Formula: (Submissions / Views) * 100
    var conversionRate = (totalSubmissions / totalViews) * 100;
    
    // Update the UI dynamically
    document.querySelector('.stats-grid').innerHTML += 
        '<div class="card">' +
            '<h4>Conversion Rate</h4>' +
            '<div class="value">' + conversionRate.toFixed(2) + '%</div>' +
        '</div>';
    </script>
    <script src="http://localhost:3000/widget.js"></script>

</body>
</html>