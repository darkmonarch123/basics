<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Dashboard | FeedbackFlow</title>
    <style>
        body { font-family: sans-serif; margin: 0; display: flex; height: 100vh; background: #f4f7f6; }
        nav { width: 220px; background: #1e293b; color: white; padding: 20px; }
        main { flex-grow: 1; padding: 40px; }
        table { width: 100%; border-collapse: collapse; background: white; border-radius: 8px; overflow: hidden; }
        th, td { padding: 15px; text-align: left; border-bottom: 1px solid #eee; }
        th { background: #f8fafc; }
        .code-block { background: #1e293b; color: #a5b4fc; padding: 15px; border-radius: 5px; font-family: monospace; }
    </style>
</head>
<body>

    <nav>
        <h2>FeedbackFlow</h2>
        <p>Logged in as: <br><strong><%= user.email %></strong></p>
        <p style="color: #fbbf24;">Plan: <%= user.plan %></p>
    </nav>

    <main>
        <h1>Your Customer Feedback</h1>
        
        <div style="background: white; padding: 20px; border-radius: 8px; margin-bottom: 30px;">
            <h3>Install your widget</h3>
            <p>Copy and paste this right before your closing <code>&lt;/body&gt;</code> tag:</p>
            <div class="code-block">
                &lt;script&gt;<br>
                &nbsp;&nbsp;window.FeedbackFlowConfig = { tenantId: '<%= user.id %>', color: '#10b981' };<br>
                &lt;/script&gt;<br>
                &lt;script src="http://localhost:3000/widget.js"&gt;&lt;/script&gt;
            </div>
        </div>

        <table>
            <tr>
                <th>Date</th>
                <th>User Email</th>
                <th>Feedback Message</th>
            </tr>
            <% if (feedbacks.length > 0) { %>
                <% feedbacks.forEach(function(fb) { %>
                    <tr>
                        <td><%= fb.date %></td>
                        <td><strong><%= fb.userEmail %></strong></td>
                        <td><%= fb.message %></td>
                    </tr>
                <% }); %>
            <% } else { %>
                <tr><td colspan="3">No feedback yet. Install the widget to get started!</td></tr>
            <% } %>
        </table>
    </main>

    <script>
        window.FeedbackFlowConfig = { tenantId: '<%= user.id %>', color: '#1e293b' };
    </script>
    <script src="http://localhost:3000/widget.js"></script>

</body>
</html>